{
  "overrides": [
    {
      "files": ["*.ts"],
      "rules": {
        "@angular-eslint/no-host-metadata-property": [
          "error",
          {
            "allowStatic": true
          }
        ],
        "@angular-eslint/component-class-suffix": 0,
        "@angular-eslint/directive-class-suffix": 0
      }
    }
  ]
}
