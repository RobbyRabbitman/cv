{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "sync": {
    "applyChanges": true
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/ci.yml"],
    "ci": [
      {
        "env": "CI"
      }
    ],
    "vitestGlobals": [
      "{projectRoot}/tools/vitest/**/*",
      {
        "externalDependencies": [
          "vite",
          "vitest",
          "@vitest/ui",
          "@vitest/coverage-v8",
          "@nx/vite"
        ]
      }
    ],
    "test-vitest": ["default", "vitestGlobals"],
    "eslintGlobals": [
      "{workspaceRoot}/tools/eslint/**/*",
      {
        "externalDependencies": [
          "@eslint/js",
          "@nx/eslint",
          "@types/eslint-config-prettier",
          "angular-eslint",
          "eslint",
          "eslint-config-prettier",
          "eslint-plugin-chai-friendly",
          "eslint-plugin-n",
          "globals",
          "jsonc-eslint-parser",
          "typescript-eslint"
        ]
      }
    ],
    "lint-eslint": ["default", "eslintGlobals"]
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck-tsc"
        },
        "build": {
          "targetName": "build-tsc",
          "configName": "tsconfig.lib.json"
        }
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint-eslint"
      }
    },
    {
      "plugin": "@nx/vite/plugin",
      "options": {
        "buildTargetName": "build-vite",
        "testTargetName": "test-vitest"
      }
    }
  ],
  "targetDefaults": {
    "lint-eslint": {
      "inputs": ["lint-eslint"],
      "options": {
        "report-unused-disable-directives": true
      }
    },
    "test-vitest": {
      "inputs": ["test-vitest", "^test-vitest"],
      "defaultConfiguration": "local",
      "configurations": {
        "local": {
          "ui": true
        },
        "ci": {
          "run": true
        }
      }
    }
  }
}
