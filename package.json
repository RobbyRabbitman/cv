{
  "name": "@cv/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint-staged": "lint-staged",
    "firebase": "pnpm exec firebase",
    "firebase:emulators:local": "pnpm run firebase --project=local emulators:start",
    "postinstall": "simple-git-hooks",
    "format:check": "pnpm exec nx format:check",
    "lint:fix:dependencies": "pnpm exec nx run-many --target=lint --all=true --fix --rule '@nx/dependency-checks'",
    "lint:affected": "pnpm exec nx affected --target lint --max-warnings=0",
    "lint:affected:fix:dependencies": "pnpm run lint:affected --fix --rule '@nx/dependency-checks'",
    "test:affected": "pnpm exec nx affected --target test",
    "build:affected": "pnpm exec nx affected --target build",
    "lint:affected:ci": "pnpm run lint:affected --configuration=ci --parallel=3",
    "test:affected:ci": "pnpm run lint:affected --configuration=ci --parallel=3",
    "build:affected:ci": "pnpm run lint:affected --configuration=ci --parallel=3",
    "ci": "pnpm run lint:affected:ci && pnpm run test:affected:ci && pnpm run build:affected:ci",
    "ci:local": "pnpm run lint:affected && pnpm run test:affected && pnpm run build:affected",
    "web:serve:local": "pnpm exec nx serve web --configuration=local",
    "web:dev": "pnpm run '/(web:serve:local|firebase:emulators:local)/'"
  },
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.12.1",
  "dependencies": {
    "@angular/animations": "18.0.1",
    "@angular/common": "18.0.1",
    "@angular/compiler": "18.0.1",
    "@angular/core": "18.0.1",
    "@angular/forms": "18.0.1",
    "@angular/platform-browser": "18.0.1",
    "@angular/platform-browser-dynamic": "18.0.1",
    "@angular/router": "18.0.1",
    "@ngrx/operators": "17.2.0",
    "@ngrx/signals": "17.2.0",
    "firebase": "10.7.2",
    "ngxtension": "1.12.0",
    "rxjs": "7.8.0",
    "tslib": "2.3.0",
    "uuid": "9.0.1",
    "zone.js": "0.14.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "18.0.2",
    "@angular-devkit/core": "18.0.2",
    "@angular-devkit/schematics": "18.0.2",
    "@angular-eslint/eslint-plugin": "17.3.0",
    "@angular-eslint/eslint-plugin-template": "17.3.0",
    "@angular-eslint/template-parser": "17.3.0",
    "@angular/cli": "~18.0.0",
    "@angular/compiler-cli": "18.0.1",
    "@angular/language-service": "18.0.1",
    "@nx/angular": "19.1.1",
    "@nx/cypress": "19.1.1",
    "@nx/devkit": "19.1.1",
    "@nx/eslint": "19.1.1",
    "@nx/eslint-plugin": "19.1.1",
    "@nx/js": "19.1.1",
    "@nx/playwright": "19.1.1",
    "@nx/workspace": "19.1.1",
    "@playwright/test": "1.36.0",
    "@schematics/angular": "18.0.2",
    "@swc-node/register": "1.8.0",
    "@swc/core": "1.3.85",
    "@types/jasmine": "5.1.4",
    "@types/node": "18.19.9",
    "@types/uuid": "9.0.7",
    "@typescript-eslint/eslint-plugin": "7.9.0",
    "@typescript-eslint/parser": "7.9.0",
    "@web/test-runner": "0.18.2",
    "@web/test-runner-core": "0.13.2",
    "autoprefixer": "10.4.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-playwright": "1.5.4",
    "firebase-tools": "13.0.3",
    "jasmine-core": "5.1.2",
    "jsonc-eslint-parser": "2.1.0",
    "lint-staged": "15.2.0",
    "ng-packagr": "18.0.0",
    "nx": "19.1.1",
    "postcss": "8.4.6",
    "postcss-import": "14.1.0",
    "postcss-preset-env": "7.5.0",
    "postcss-url": "10.1.3",
    "prettier": "3.2.4",
    "prettier-plugin-organize-imports": "3.2.4",
    "simple-git-hooks": "2.9.0",
    "tailwindcss": "3.4.1",
    "ts-node": "10.9.1",
    "typescript": "5.4.5"
  }
}
