{
  "name": "@robby-rabbitman/cv-tools-eslint",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "typescript-eslint": "8.18.0",
    "angular-eslint": "19.0.2",
    "@eslint/js": "9.16.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-chai-friendly": "1.0.1",
    "eslint": "9.16.0",
    "eslint-plugin-n": "17.14.0",
    "@nx/eslint-plugin": "20.2.2",
    "jsonc-eslint-parser": "2.4.0",
    "globals": "15.13.0"
  },
  "nx": {
    "tags": [
      "type:tool"
    ],
    "targets": {
      "sync-dependencies": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": false,
          "commands": [
            {
              "description": "Need to build every project and reset project graph before syncing dependencies ...",
              "command": "nx run-many -t build build-tsc build-angular && nx reset"
            },
            "nx run-many -t lint-eslint --fix --rule '@nx/dependency-checks:error'"
          ]
        }
      }
    }
  }
}
