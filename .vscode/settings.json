{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "$(capture).html, $(capture).scss, $(capture).ts, $(capture).spec.ts",
    "jest.config.ts": "jest.preset.js",
    ".eslintrc.json": ".eslint*",
    ".editorconfig": ".prettier*",
    ".firebaserc": "firebase*, *-debug.log",
    "README*": "CHANGELOG*",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, ng-package.json, project.json, nx.json"
  }
}
